<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Profile</title>
</head>

<body>

    <h1>
        <%= name %>
    </h1>

    <p>
        <%= role %>
    </p>

    <% if (isOnline) { %>
        <p>Онлайн</p>
        <% } else { %>
            <p>Офлайн</p>
            <% } %>

                <h3>Хобі:</h3>

                <ul>
                    <% hobbies.forEach(hobby=> { %>
                        <li>
                            <%= hobby %>
                        </li>
                        <% }) %>
                </ul>

</body>

</html>